# ==========================================
# 1. 核心私有资产 (禁止上传)
# ==========================================
# 忽略私有模型文件夹，保护核心研究成果
my_private_models/

# ==========================================
# 2. 模块运行时生成的动态缓存与数据
# ==========================================
# Logger 模块：忽略所有自动生成的会话日志和元数据
module_logger/logs/

# MCP 模块：忽略运行时缓存、会话快照、本地预设参数
module_mcp/mcp_cache/

# RAG 模块：忽略巨大的 ChromaDB 向量数据库本地文件
module_rag/chroma_db/

# ==========================================
# 3. 仿真产生的临时文件
# ==========================================
# 忽略分析时导出的波形数据或临时缓存
*.csv
*.dat
*.tmp
*.mat

# ==========================================
# 4. Python 系统级垃圾文件
# ==========================================
# 忽略虚拟环境 (不传 node_modules 或 venv)
.venv/
venv/
env/

# 忽略 Python 编译字节码缓存
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# 5. 操作系统垃圾文件
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
